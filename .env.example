# learn-cc 环境变量配置
# 复制此文件为 .env 后填入真实值

ANTHROPIC_API_KEY=sk-your-api-key-here
MODEL_ID=claude-sonnet-4-20250514

# 可选：自定义 API 地址（兼容 Anthropic 接口的第三方提供商）
# ANTHROPIC_BASE_URL=https://api.example.com/anthropic

# 可选：权限系统自定义 deny 正则（分号分隔，空=用代码默认值）
# PERMISSION_DENY_PATTERNS=\brm\s+-[rf]{1,2}\b;\bshutdown\b

# 可选：权限系统 allowlist（分号分隔，非空时启用白名单模式，只有匹配的放行）
# PERMISSION_ALLOW_PATTERNS=echo;ls;git
